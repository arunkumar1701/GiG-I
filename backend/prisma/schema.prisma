generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Driver {
  id                  Int                 @id @default(autoincrement())
  fullName            String
  city                String
  zone                String
  platform            String
  weeklyIncome        Float
  vehicleType         String              @default("Bike")
  vehicleNumber       String?
  planTier            String              @default("Standard")
  shiftStatus         String              @default("Offline")
  phoneMasked         String?
  phoneHash           String?             @unique
  phoneEncrypted      String?
  upiHash             String?
  upiEncrypted        String?
  bankName            String?
  bankAccountLast4    String?
  bankAccountHash     String?
  bankAccountEncrypted String?
  ifscHash            String?
  ifscEncrypted       String?
  emergencyContactMasked String?
  emergencyContactHash String?
  emergencyContactEncrypted String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  policies            Policy[]
  claimEvents         ClaimEvent[]
  walletTransactions  WalletTransaction[]
}

model Policy {
  id             Int          @id @default(autoincrement())
  driverId       Int
  premiumAmount  Float
  activeStatus   Boolean      @default(true)
  startDate      DateTime     @default(now())
  endDate        DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  driver         Driver       @relation(fields: [driverId], references: [id], onDelete: Cascade)
  claimEvents    ClaimEvent[]

  @@index([driverId, activeStatus, endDate])
}

model ClaimEvent {
  id                    Int                 @id @default(autoincrement())
  policyId              Int
  driverId              Int
  zone                  String
  triggerType           String
  payoutAmount          Float
  timestamp             DateTime            @default(now())
  frs1                  Float?
  frs2                  Float?
  frs3                  Float?
  frsLocation           Float?
  frsDevice             Float?
  frsBehavior           Float?
  frsNetwork            Float?
  frsEvent              Float?
  explanation           String?
  status                String              @default("Pending")
  transactionId         String?
  tokenId               Int?
  dataHash              String?
  rainMmAtTrigger       Float?
  aqiAtTrigger          Float?
  driverLat             Float?
  driverLon             Float?
  deviceHash            String?
  ipAddressHash         String?
  upiHash               String?
  clusterFlagged        Boolean             @default(false)
  policy                Policy              @relation(fields: [policyId], references: [id], onDelete: Cascade)
  driver                Driver              @relation(fields: [driverId], references: [id], onDelete: Cascade)
  walletTransaction     WalletTransaction?

  @@index([driverId, timestamp])
  @@index([zone, timestamp])
  @@index([status, timestamp])
}

model WalletTransaction {
  id              Int       @id @default(autoincrement())
  driverId        Int
  claimEventId    Int?      @unique
  tokenId         Int?
  txType          String    @default("payout")
  event           String
  amount          Float
  transactionId   String?
  status          String    @default("Pending")
  timestamp       DateTime  @default(now())
  driver          Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  claimEvent      ClaimEvent? @relation(fields: [claimEventId], references: [id], onDelete: SetNull)

  @@index([driverId, timestamp])
}
